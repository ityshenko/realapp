# ===========================================
# НАСТРОЙКИ ПРОЕКТА REALAPP
# ===========================================

# -------------------------------------------
# БАЗА ДАННЫХ (PostgreSQL)
# -------------------------------------------
# Для локальной разработки:
DATABASE_URL="postgresql://postgres:password@localhost:5432/realapp?schema=public"

# Для продакшена (замените на ваши данные):
# DATABASE_URL="postgresql://user:password@host:5432/realapp?schema=public"

# -------------------------------------------
# СЕРВЕР (Backend)
# -------------------------------------------
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# -------------------------------------------
# БЕЗОПАСНОСТЬ (JWT)
# -------------------------------------------
# Сгенерируйте случайную строку для продакшена!
JWT_SECRET="your_super_secret_jwt_key_CHANGE_IN_PRODUCTION"
JWT_EXPIRES_IN=7d

# -------------------------------------------
# ФРОНТЕНД (Next.js)
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="your_nextauth_secret_CHANGE_IN_PRODUCTION"

# -------------------------------------------
# ЗАГРУЗКА ФАЙЛОВ
# -------------------------------------------
MAX_FILE_SIZE=10485760
MAX_FILES=20
UPLOAD_DIR=./public/uploads

# -------------------------------------------
# АДМИН (по умолчанию)
# -------------------------------------------
ADMIN_EMAIL=admin@tut.ru
ADMIN_PASSWORD=admin123

# ===========================================
# ИНСТРУКЦИЯ ПО НАСТРОЙКЕ
# ===========================================
# 1. Скопируйте этот файл как .env
# 2. Установите PostgreSQL
# 3. Создайте базу данных: CREATE DATABASE realapp;
# 4. Измените DATABASE_URL на ваши данные
# 5. Смените JWT_SECRET и NEXTAUTH_SECRET на случайные строки
# 6. Запустите: npm run db:push
# ===========================================
